{
  "name": "NgobeApp",
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node --test  \"tests/*.test.cjs\"",
    "test:security": "pnpm audit",
    "test:mass": "pnpm run test && pnpm run test:security",
    "lint": "eslint src tests backend --ext .js,.jsx,.cjs",
    "lint:fix": "eslint src tests backend --ext .js,.jsx,.cjs --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"tests/**/*.{cjs,js}\" \"backend/**/*.js\"",
    "test:full": "pnpm run test:mass && pnpm run lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@babel/plugin-transform-async-generator-functions": "^7.28.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.27.1",
    "@babel/plugin-transform-numeric-separator": "^7.27.1",
    "@babel/plugin-transform-object-rest-spread": "^7.28.0",
    "@babel/plugin-transform-optional-catch-binding": "^7.27.1",
    "@babel/plugin-transform-optional-chaining": "^7.27.1",
    "@npmcli/fs": "^4.0.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/voice": "^1.1.9",
    "@react-native/babel-preset": "^0.81.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.14.12",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.15.2",
    "expo": "^55.0.15",
    "expo-av": "^16.0.8",
    "lru-cache": "^11.1.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.3"
  }
}
